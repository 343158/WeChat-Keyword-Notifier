<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="微信关键词提醒器"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- 语音播报开关 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="#E8F5E9"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔊 语音播报"
            android:textSize="16sp"
            android:textColor="#333333" />

        <Switch
            android:id="@+id/switchTTS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 4个快捷入口 (2x2 Grid) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnKeywords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="关键词设置"
            android:textSize="14sp"
            android:drawableTop="@android:drawable/ic_menu_edit"
            android:padding="16dp"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnViewMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="查看消息"
            android:textSize="14sp"
            android:drawableTop="@android:drawable/ic_menu_agenda"
            android:padding="16dp"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnRingtone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="关键词铃声"
            android:textSize="14sp"
            android:drawableTop="@android:drawable/ic_menu_manage"
            android:padding="16dp"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="个性设置"
            android:textSize="14sp"
            android:drawableTop="@android:drawable/ic_menu_preferences"
            android:padding="16dp"
            android:layout_margin="4dp" />
    </GridLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="8dp" />

    <!-- 消息记录标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="匹配消息记录"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnClearHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="清空"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 消息列表 -->
    <ListView
        android:id="@+id/lvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

    <!-- 状态栏 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="需授权通知监听权限"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="6dp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
